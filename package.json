{
  "name": "secure-chat",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:client\" \"npm:dev:server\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch server/index.ts",
    "dev:e2e": "concurrently -k \"npm:dev:e2e:server\" \"npm:dev:e2e:client\"",
    "dev:e2e:server": "PORT=8788 tsx server/index.ts",
    "dev:e2e:client": "SIGNALING_TARGET=http://127.0.0.1:8788 vite --host 127.0.0.1 --port 5180 --strictPort",
    "build": "npm run build:client && npm run build:server && npm run build:worker",
    "build:client": "tsc --noEmit && vite build",
    "build:server": "tsc -p server/tsconfig.json",
    "build:worker": "tsc -p worker/tsconfig.json --noEmit",
    "preview": "vite preview --host 0.0.0.0",
    "preview:cloudflare": "npm run build:client && wrangler dev",
    "start": "node dist-server/index.js",
    "test": "npm run test:unit",
    "test:unit": "vitest run tests/identity.test.ts tests/session.test.ts tests/fileTransfer.test.ts",
    "test:server": "vitest run tests/signaling.test.ts",
    "test:e2e": "playwright test --project=chromium",
    "test:security": "node scripts/security-check.mjs && npm audit --audit-level=moderate",
    "test:all": "npm run typecheck && npm run lint && npm run test:unit && npm run test:server && npm run build && npm run test:security && npm run test:e2e",
    "typecheck": "tsc --noEmit && tsc -p server/tsconfig.json --noEmit && tsc -p worker/tsconfig.json --noEmit",
    "lint": "eslint .",
    "deploy:cloudflare": "npm run build:client && npm run build:worker && wrangler deploy"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^5.0.0",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260630.1",
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.61.1",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  }
}
